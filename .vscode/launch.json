{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "NiceGUI Debugging",
            "type": "debugpy",
            "request": "launch",
            "module": "src.frontend.main",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Turbo Litestar Debugging",
            "type": "debugpy",
            "request": "launch",
            "module": "litestar",
            "justMyCode": true,
            "args": [
                "--app=src.backend.main:app",
                "run",
                "--debug"
            ],
            "console": "integratedTerminal"
        },

        
        {
            "name": "Litestar Debugging",
            "type": "debugpy",
            "request": "launch",
            "module": "litestar",
            "justMyCode": true,
            "args": [
                "--app=src.backend.main:app",
                "run"
            ],
            "console": "integratedTerminal"
        }
    ]
}